        "import random\n",
        "\n",
        "num = random.randint(1, 10)\n",
        "guess = int(input(\"Guess a number (1-10): \"))\n",
        "\n",
        "if guess == num:\n",
        "    print(\"Correct!\")\n",
        "else:\n",
        "    print(\"Wrong! Number was\", num)"
      ]
